<%layout("/layout/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <br><br>
    <h3>Create a new Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data"  >
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input name="listing[title]" placeholder="enter title" type="text"  class="form-control" required>
            <div class="valid-feedback">
                Looks good!
            </div>
        </div>
        
        <div class="mb-3">
            <label for="description" class="form-lable">Discription</label>
            <textarea name="listing[description]"  type="text" class="form-control" required></textarea>
            <div class="invalid-feedback">please write short description</div>
        </div>
        
        <div class="mb-3">
             <label for="image" class="form-lable">upload image file</label>
             <input name="listing[image]" placeholder="upload image file" type="file" class="form-control" required>
             <div class="invalid-feedback">Please upload an image file.</div>
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
               <label for="price" class="form-lable">price</label>
               <input name="listing[price]" placeholder="enter price"  class="form-control" required>
                <div class="invalid-feedback">fill vailed price</div>
            </div>
            <div class="mb-3 col-md-8">
              <label for="country" class="form-lable">country</label>
              <input name="listing[country]" placeholder="enter country" type="text" class="form-control"required>
              <div class="invalid-feedback">fill country name</div>
            </div>
       

        </div>
       
        <div class="mb-3">
            <label for="location" class="form-lable">location</label>
            <input name="listing[location]" placeholder="enter location" type="text" class="form-control"required>
            <div class="invalid-feedback">enter location</div>
        </div>
        
        <button class="btn btn-dark add-btn mt-3">Add</button>
        <br><br>


    </form>
    </div>
    </div>
     
</body>
