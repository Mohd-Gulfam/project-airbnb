<% layout("/layout/boilerplate") %>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
    margin-top: 2rem;
    align-items: center;

  }

  .filter {

      text-align: center;
      margin-right: 2rem;
      margin-top: 2rem;
      
      opacity: 0.8;
  }

  .filter:hover {

      opacity: 1;
      cursor: pointer;
 }
 .tax-toggle {
  margin-left: auto;
  margin-top: 2rem; 
  border: 1px solid #ccc;
  padding: 0.5rem 1rem;
  border-radius: 5px;
  height: 2.5rem;
  width: fit-content;
}
.no-results-container{
display:flex;
justify-content:center;
align-items:center;
width: 100%;
}



.no-results-icon{
font-size:3rem;
color:#ff385c;
margin-bottom:1rem;
}

.no-results-card h3{
font-weight:600;
margin-bottom:0.5rem;
}

.no-results-card p{
color:gray;
margin-bottom:1rem;
}

</style>

<div class="filters ">
  <div class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </div>
    <div class="filter">
      <div><i class="fa-solid fa-earth-americas"></i></div>
      <p>Worldwide</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-house"></i></div>
      <p>Entire homes</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Unique stays</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-couch"></i></div>
      <p>Pets allowed</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-people-group"></i></div>
      <p>Family-friendly</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Beachfront</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-mountain-sun"></i></div>
      <p>Mountain</p>
    </div>
    
    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" role="switch" type="checkbox" id="taxToggle">
        <label class="form-check-label" for="taxToggle">Include taxes and fees</label>
      </div>
    </div>

</div>
<hr>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b>
                <%= listing.title %>
              </b><br>
              &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
              <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
            </p>
          </div>
        </div>
      </a>
    <% } %>
<% if(allListings.length === 0){ %>

<div class="row no-results-container">
  <div class="col-4"></div>
  <div class=" col-4 no-results-card">
    
    <i class="fa-solid fa-magnifying-glass-location no-results-icon"></i>

    <h3>No Listings Found</h3>

    <p>We couldn't find any listings matching your search.</p>

    <a href="/listings" class="btn btn-primary mt-2">
      Explore All Listings
    </a>

  </div>
  <div class="col-4"></div>

</div>

<% } %>
</div>

<script>
  const taxToggle = document.getElementById('taxToggle');
  const taxInfoElements = document.querySelectorAll('.tax-info');

  taxToggle.addEventListener('change', () => {
    taxInfoElements.forEach(el => {
      el.style.display = taxToggle.checked ? 'inline' : 'none';
    });
  });
</script>