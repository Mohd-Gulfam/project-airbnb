<% layout("/layout/boilerplate") %>
<style>

.show-card{
  padding-left: 0;
  padding-right: 0;
}

/* Review Cards */
.review-card{
  border-radius: 12px;
  padding: 10px;
}

/* Fix star overflow */
.starability-result{
  max-width: 100%;
  overflow: hidden;
}

/* Mobile Responsive */
@media(max-width:768px){

.show-card{
  margin-left: 0 !important;
}

.review-card{
  width: 100% !important;
}

.starability-result{
  transform: scale(0.9);
  transform-origin: left;
}

}

</style>

    <body>

        <div class="row mt-3">

            <div class="col-12 col-md-8 offset-md-2">
                <h3>
                    <%= listing.title %>
                </h3><br>
            </div>


            <div class="listing-card col-12 col-md-6 offset-md-3 show-card">

                <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="listing_img">

                <div class="card-body">

                    <p class="card-text">
                        <i>Owner by : <%= listing.owner.username %></i>
                    </p>

                    <br>

                    <p class="card-text">
                        <%= listing.description %>
                    </p>

                    <br>

                    <b class="card-text">
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    </b>

                    <br>

                    <p class="card-text">
                        <%= listing.location %>
                    </p>

                    <br>

                    <p class="card-text">
                        <%= listing.country %>
                    </p>

                </div>
            </div>

            <br>


            <% if(currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) {%>

                <div class="col-12 col-md-6 offset-md-3">

                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark me-2">
                        Edit
                    </a>

                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">

                        <button class="btn btn-dark">
                            Delete
                        </button>

                    </form>

                </div>

                <%} %>


                    <div class="col-12 col-md-8 offset-md-2">

                        <hr>

                        <% if(currentUser) { %>

                            <h4>Leave a review</h4>

                            <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate
                                class="needs-validation">

                                <div class="mb-3 mt-3">

                                    <label class="form-label">Rating</label>

                                    <fieldset class="starability-slot">

                                        <input type="radio" name="review[rating]" value="1">

                                        <input type="radio" name="review[rating]" value="2">

                                        <input type="radio" name="review[rating]" value="3">

                                        <input type="radio" name="review[rating]" value="4">

                                        <input type="radio" name="review[rating]" value="5">

                                    </fieldset>

                                </div>


                                <div class="mb-3">

                                    <label class="form-label">
                                        Your review
                                    </label>

                                    <textarea class="form-control" name="review[comment]" rows="3" required>
</textarea>

                                    <div class="invalid-feedback">
                                        Please write your review.
                                    </div>

                                </div>


                                <button type="submit" class="btn btn-primary">
                                    Submit Review
                                </button>

                            </form>

                            <hr>

                            <% } %>


                                <h4>All Reviews</h4>

                                <div class="row">

                                    <% for(review of listing.reviews){ %>

                                        <div class="col-12 col-md-6 mb-3">

                                            <div class="card review-card">

                                                <div class="card-body">

                                                    <p class="card-title">
                                                        <%= review.author ? review.author.username : 'Anonymous' %>
                                                    </p>

                                                    <p class="starability-result" data-rating="<%= review.rating %>">
                                                    </p>

                                                    <p class="card-text">
                                                        <%= review.comment %>
                                                    </p>

                                                    <p class="card-text">
                                                        Rating: <%= review.rating %>/5
                                                    </p>

                                                    <form method="POST"
                                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                                        <button class="btn btn-danger mt-2">
                                                            Delete
                                                        </button>

                                                    </form>

                                                </div>

                                            </div>

                                        </div>

                                        <% } %>

                                </div>

                    </div>

        </div>

    </body>