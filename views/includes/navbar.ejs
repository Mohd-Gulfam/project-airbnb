<style>
/* Navbar */
.navbar {
  background-color: #ebebeb ;
  border-bottom: 1px solid #ddd;
}

/* Logo */
.navbar-brand i {
  color: #ff385c;
  font-size: 1.5rem;
}

/* Search bar */
.search-input {
  border-radius: 25px;
  padding: 0.5rem 1rem;
  border: 1px solid #ddd;
}

/* Search Button */
.btn-search {
  background-color: #ff385c;
  color: white;
  border-radius: 25px;
  padding: 0.4rem 1rem;
}

.btn-search:hover {
  background-color: #ff385c;
  color: white;
}

/* Right Links */
.navbar-nav .nav-link {
  font-weight: 500;
  margin-left: 10px;
}

/* Mobile Fix */
@media(max-width:992px){

.navbar-collapse{
  padding-top:10px;
}

.search-input{
  width:100%;
  margin-bottom:10px;
}

.btn-search{
  width:100%;
}

}
</style>


<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">

    <!-- Logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- Toggle -->
    <button 
    class="navbar-toggler" 
    type="button"
    data-bs-toggle="collapse"
    data-bs-target="#navbarNav"
    aria-controls="navbarNav"
    aria-expanded="false"
    aria-label="Toggle navigation">

      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Content -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left -->
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/listings">All Listings</a>
        </li>
      </ul>

      <!-- Center Search -->
      <form 
      class="d-flex flex-column flex-lg-row mx-lg-auto my-2 my-lg-0"
      action="/listings/search"
      method="GET">

        <input
        class="form-control search-input me-lg-2"
        type="search"
        placeholder="Search destinations"
        name="location">

        <button class="btn btn-search">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>

      </form>

      <!-- Right -->
      <ul class="navbar-nav ms-lg-auto">

        <li class="nav-item">
          <a class="nav-link" href="/listings/new">
            Airbnb your Home
          </a>
        </li>

        <% if(!currentUser){ %>

        <li class="nav-item">
          <a class="nav-link" href="/signup">Signup</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/login">Login</a>
        </li>

        <% } else { %>

        <li class="nav-item">
          <a class="nav-link" href="/users/profile">
            <i class="fa-solid fa-user"></i>
            <%= currentUser.username %>
          </a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/logout">Logout</a>
        </li>

        <% } %>

      </ul>

    </div>

  </div>
</nav>